---
// 任务书详情页：正文走 .prose 排版，头部集中展示状态 / 报酬 / 截止时间。
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../lib/news.mjs';

export async function getStaticPaths() {
  const tasks = await getCollection('tasks');
  return tasks.map((task) => ({ params: { slug: task.id }, props: { task } }));
}

const { task } = Astro.props;
const { Content } = await render(task);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isOpen = task.data.status === 'open';
const isTaken = task.data.status === 'taken';
const statusLabel = isOpen
  ? '招募中'
  : isTaken
    ? `进行中${task.data.taker ? ` · ${task.data.taker}` : ''}`
    : task.data.status === 'done' ? '完工待打款' : '已收官';
---

<BaseLayout title={task.data.title} description={task.data.summary}>
  <article class="prose task-prose">
    <p class="crumb"><a href={`${base}/tasks/`}>任务书</a> / {statusLabel}</p>
    <h1>{task.data.title}</h1>
    <div class="task-meta">
      <span class:list={['tm-status', { 'is-open': isOpen, 'is-taken': isTaken }]}>{statusLabel}</span>
      {task.data.fee && <span class="tm-item">报酬 <b>{task.data.fee}</b></span>}
      {task.data.deadline && <span class="tm-item">截止 <b>{formatDate(task.data.deadline)}</b></span>}
      <span class="tm-item">发布 <b>{formatDate(task.data.date)}</b></span>
    </div>
    <Content />
    <p class="back"><a href={`${base}/tasks/`}>← 返回全部任务书</a></p>
  </article>
</BaseLayout>

<style>
  .crumb { font-family: var(--sans); font-size: .8rem; color: var(--ink-soft); margin: 0 0 1rem; }
  .task-prose h1 { margin-top: 0; }

  .task-meta {
    display: flex; flex-wrap: wrap; align-items: baseline; gap: .6rem 1.4rem;
    padding: .9rem 0 1.1rem; margin: 0 0 1.4rem; border-bottom: 2px solid var(--ink);
    font-family: var(--sans); font-size: .86rem; color: var(--ink-soft);
  }
  .task-meta b { color: var(--ink); font-variant-numeric: tabular-nums; font-weight: 600; }
  .tm-status {
    font-size: .68rem; letter-spacing: .14em; text-transform: uppercase;
    border-radius: 999px; padding: .18em .7em; white-space: nowrap;
    color: var(--ink-soft); border: 1px solid var(--line);
  }
  .tm-status.is-open { color: var(--accent); border-color: color-mix(in srgb, var(--accent) 45%, var(--line)); background: var(--accent-soft); }
  .tm-status.is-taken { text-transform: none; }

  .back { margin-top: 3rem; font-family: var(--sans); font-size: .88rem; }
</style>
