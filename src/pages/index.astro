---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SpiderWeb from '../components/SpiderWeb.astro';
import { SELECTED, categoryLabel } from '../lib/kb.mjs';
import { getTitle, getCategory, getSubCategory, getExcerpt, href } from '../lib/notes.mjs';
import { games } from '../data/games.js';
import { getEpisodes, getLatestEpisodes } from '../lib/prompt-master.mjs';

// base-aware 链接：兼容 GitHub Pages 子路径与自定义域名根路径
const gamesBase = import.meta.env.BASE_URL.replace(/\/$/, '');
const gameHref = (g) => (/^https?:/.test(g.path) ? g.path : gamesBase + g.path);

// 「成为 Prompt 大师」系列：构建时读取同步进 public/ 的画廊数据，首页展示最新几期封面。
const seriesBase = import.meta.env.BASE_URL.replace(/\/$/, '') + '/prompt-master/';
const seriesTotal = getEpisodes().length;
const latestEpisodes = getLatestEpisodes(4);
const coverSrc = (e) => seriesBase + encodeURI(e.folder) + '/' + encodeURI(e.cover);

const notes = await getCollection('notes');

const cats = SELECTED.map(categoryLabel);
const counts = Object.fromEntries(cats.map((c) => [c, 0]));

// 栏目 → 子栏目（保序）→ 计数
const subOf = Object.fromEntries(cats.map((c) => [c, new Map()]));

const items = notes.map((n) => {
  const cat = getCategory(n);
  const sub = getSubCategory(n);
  if (cat in counts) counts[cat]++;
  if (sub && subOf[cat]) subOf[cat].set(sub, (subOf[cat].get(sub) || 0) + 1);
  return { id: n.id, title: getTitle(n), excerpt: getExcerpt(n), cat, sub };
});
items.sort(
  (a, b) =>
    a.cat.localeCompare(b.cat, 'zh') ||
    (a.sub || '').localeCompare(b.sub || '', 'zh') ||
    a.title.localeCompare(b.title, 'zh')
);
const total = items.length;

// 栏目一句话定位，给每个分区一点编辑性引导
const DESC = {
  '方法论与洞察': '可复用的创作心法、审美判断与踩坑记录。',
  'prompt模板库': '可直接套用的提示词模板与案例复盘。',
  'sref档案': '风格参考码（sref）的实测与归档。',
  '参数行为档案': '模型参数的行为规律与边界实验。',
  '视觉系统': 'IP 视觉系统与世界观设定。',
  'skill存档': 'AIGC 创作技能包（Skill）的存档与说明，按技能分簇。',
};

// 组装分区结构：每栏目 → 无子类的散篇(loose) + 各子类簇(subs)，均按 SELECTED 顺序
const groups = cats.map((cat) => {
  const catItems = items.filter((i) => i.cat === cat);
  const loose = catItems.filter((i) => !i.sub);
  const subs = [...subOf[cat].keys()].map((name) => ({
    name,
    items: catItems.filter((i) => i.sub === name),
  }));
  return { cat, count: counts[cat], desc: DESC[cat] || '', loose, subs };
});

// 子栏目数据 + 栏目真实总数，交给前端脚本驱动二级筛选条
const subsByCat = Object.fromEntries(
  cats.map((c) => [c, [...subOf[c].entries()].map(([name, n]) => ({ name, n }))])
);
const catCounts = counts;
---

<BaseLayout description="跳蛛先生的 AIGC 创作方法论公开知识库 —— 杂志风 · 可游的知识网络。">
  <section class="hero">
    <SpiderWeb />
    <div class="hero-inner">
      <h1>蛛网之上</h1>
      <p>
        跳蛛先生的 AIGC 创作方法论知识库。<span class="count-up" id="hero-count" data-target={total}>{total}</span>
        篇可复用的 insight，织成一张可游的知识网。
      </p>
    </div>
  </section>

  {latestEpisodes.length > 0 && (
    <section class="series" id="prompt-master">
      <div class="series-head">
        <h2>成为 Prompt 大师 <span>· Prompt Master</span></h2>
        <p>
          面向 AIGC 小白的 prompt 拆解系列：每期一个 battle 主题，讲清「难在哪 → 怎么破题 → 完整 prompt → 四层拆解」。不追结果，记录过程。
        </p>
      </div>
      <div class="series-grid">
        {latestEpisodes.map((e) => (
          <a class="series-card" href={seriesBase}>
            <div class="series-cover">
              <img src={coverSrc(e)} alt={e.title} loading="lazy" width="300" height="400" />
            </div>
            <div class="series-meta">
              <span class="series-no">{e.no}</span>
              <h3>{e.title}</h3>
              <p>{e.sub}</p>
            </div>
          </a>
        ))}
        <a class="series-card series-all" href={seriesBase}>
          <div class="series-all-inner">
            <span class="series-all-arrow">→</span>
            <h3>查看全部 {seriesTotal} 期</h3>
            <p>进入完整画廊</p>
          </div>
        </a>
      </div>
    </section>
  )}

  <section class="plays" id="plays">
    <div class="plays-head">
      <h2>可玩 <span>· Plays</span></h2>
      <p>能在浏览器里直接打开就玩的小东西——用 vibe coding 做的互动作品，国内直连、无需安装。</p>
    </div>
    <div class="play-grid">
      {games.map((g) => (
        <a class="play-card" href={gameHref(g)} style={`--g-accent:${g.accent}`}>
          <div class="play-badge">{g.emoji}</div>
          <div class="play-body">
            <span class="play-status">{g.status}</span>
            <h3>{g.title}</h3>
            <p class="play-tagline">{g.tagline}</p>
            <p class="play-desc">{g.desc}</p>
            <div class="play-tags">{g.tags.map((t) => <span>{t}</span>)}</div>
            <span class="play-cta">开始游玩 →</span>
          </div>
        </a>
      ))}
      <div class="play-card play-soon" aria-hidden="true">
        <div class="play-badge">＋</div>
        <div class="play-body">
          <h3>更多游戏开发中</h3>
          <p class="play-desc">新的 vibe coding 作品会持续发布在这里。</p>
        </div>
      </div>
    </div>
  </section>

  <div class="explore">
    <div class="chips" id="chips">
      <button class="chip is-active" data-cat="*">全部 <i>{total}</i></button>
      {cats.map((c) => (
        <button class="chip" data-cat={c}>{c} <i>{counts[c]}</i></button>
      ))}
    </div>
    <div class="subchips" id="subchips" hidden></div>
  </div>

  <section class="section">
    <div class="section-head">
      <span class="result-count" id="result-count"><b>{total}</b> / {total} 篇</span>
    </div>

    {groups.map((g) => (
      <div class="cat-block" data-cat={g.cat}>
        <header class="cat-head">
          <h2>{g.cat}</h2>
          <span class="cat-count">{g.count} 篇</span>
          {g.desc && <p class="cat-desc">{g.desc}</p>}
        </header>

        {g.loose.length > 0 && (
          <div class="cards cards-loose">
            {g.loose.map((n) => (
              <a class="card" data-cat={n.cat} data-sub={n.sub || ''} data-title={n.title} href={href(n.id)}>
                <h3>{n.title}</h3>
                <p>{n.excerpt}</p>
              </a>
            ))}
          </div>
        )}

        {g.subs.map((s) => (
          <div class="sub-block" data-sub={s.name}>
            <h3 class="sub-head">{s.name} <i>{s.items.length}</i></h3>
            <div class="cards">
              {s.items.map((n) => (
                <a class="card" data-cat={n.cat} data-sub={n.sub || ''} data-title={n.title} href={href(n.id)}>
                  <h3>{n.title}</h3>
                  <p>{n.excerpt}</p>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    ))}

    <p class="empty" id="empty" hidden>该分类暂无内容</p>
  </section>
</BaseLayout>

<script is:inline define:vars={{ subsByCat, catCounts, total }}>
  const chips = [...document.querySelectorAll('#chips .chip')];
  const subBar = document.getElementById('subchips');
  const empty = document.getElementById('empty');
  const resultCount = document.getElementById('result-count');
  const blocks = [...document.querySelectorAll('.cat-block')];

  let activeCat = '*';
  let activeSub = '*';

  function apply() {
    let shown = 0;
    for (const block of blocks) {
      const catOk = activeCat === '*' || block.dataset.cat === activeCat;
      block.style.display = catOk ? '' : 'none';
      if (!catOk) continue;

      const subBlocks = block.querySelectorAll('.sub-block');
      const loose = block.querySelector('.cards-loose');
      if (subBlocks.length) {
        subBlocks.forEach((sb) => {
          const subOk = activeSub === '*' || sb.dataset.sub === activeSub;
          sb.style.display = subOk ? '' : 'none';
          if (subOk) shown += sb.querySelectorAll('.card').length;
        });
        if (loose) {
          const looseOk = activeSub === '*';
          loose.style.display = looseOk ? '' : 'none';
          if (looseOk) shown += loose.querySelectorAll('.card').length;
        }
      } else {
        shown += block.querySelectorAll('.card').length;
      }
    }
    if (empty) empty.hidden = shown > 0;
    if (resultCount) resultCount.innerHTML = `<b>${shown}</b> / ${total} 篇`;
  }

  function renderSubBar(cat) {
    const subs = cat === '*' ? [] : (subsByCat[cat] || []);
    if (!subs.length) { subBar.hidden = true; subBar.innerHTML = ''; return; }
    const catCount = catCounts[cat] ?? subs.reduce((a, s) => a + s.n, 0);
    let html = '<span class="sub-label">细分</span>';
    html += `<button class="subchip is-active" data-sub="*">全部 <i>${catCount}</i></button>`;
    for (const s of subs) html += `<button class="subchip" data-sub="${s.name}">${s.name} <i>${s.n}</i></button>`;
    subBar.innerHTML = html;
    subBar.hidden = false;
    subBar.querySelectorAll('.subchip').forEach((sc) => {
      sc.addEventListener('click', () => {
        subBar.querySelectorAll('.subchip').forEach((x) => x.classList.remove('is-active'));
        sc.classList.add('is-active');
        activeSub = sc.dataset.sub;
        apply();
      });
    });
  }

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.classList.remove('is-active'));
      chip.classList.add('is-active');
      activeCat = chip.dataset.cat;
      activeSub = '*';
      renderSubBar(activeCat);
      apply();
      // 选定栏目后平滑滚到内容区，强化"切换"反馈
      if (activeCat !== '*') {
        const target = document.querySelector(`.cat-block[data-cat="${CSS.escape(activeCat)}"]`);
        target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  apply();

  // 标题数字 count-up（尊重 reduced-motion）
  const el = document.getElementById('hero-count');
  const target = el ? +el.dataset.target : 0;
  if (el && target && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const start = performance.now();
    const dur = 900;
    el.textContent = '0';
    const tick = (now) => {
      const p = Math.min(1, (now - start) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(eased * target).toString();
      if (p < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }
</script>

<style>
  /* 成为 Prompt 大师 —— 旗舰发刊系列，独立版块，展示最新几期封面 */
  .series { max-width: 72rem; margin: 0 auto; padding: 2.5rem 1.5rem .5rem; }
  .series-head h2 { font-family: var(--serif); font-size: 1.5rem; margin: 0 0 .3rem; display: flex; align-items: baseline; gap: .5rem; flex-wrap: wrap; }
  .series-head h2 span { font-family: var(--sans); font-weight: 400; font-size: .78rem; letter-spacing: .26em; text-transform: uppercase; color: var(--ink-soft); }
  .series-head p { margin: 0 0 1.3rem; color: var(--ink-soft); font-size: .92rem; max-width: 46rem; line-height: 1.7; }

  .series-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(13.5rem, 1fr)); gap: 1rem; }

  .series-card {
    display: flex; flex-direction: column; overflow: hidden; background: var(--paper-2);
    border: 1px solid var(--line); border-radius: 14px; text-decoration: none;
    transition: transform .2s cubic-bezier(.2,.7,.3,1), box-shadow .2s ease, border-color .2s ease;
  }
  .series-card:hover {
    transform: translateY(-4px); text-decoration: none;
    box-shadow: 0 16px 40px -16px rgba(var(--shadow), .5);
    border-color: color-mix(in srgb, var(--accent) 55%, var(--line));
  }
  .series-cover { aspect-ratio: 3 / 4; overflow: hidden; background: var(--paper-3); }
  .series-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .series-meta { padding: .8rem .9rem 1rem; min-width: 0; }
  .series-no { font-size: .68rem; letter-spacing: .14em; text-transform: uppercase; color: var(--accent); }
  .series-card h3 { font-family: var(--serif); font-size: 1.02rem; margin: .25rem 0 .35rem; color: var(--ink); }
  .series-meta p { margin: 0; font-size: .8rem; color: var(--ink-soft); line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

  /* 末尾「查看全部」卡 */
  .series-all { align-items: center; justify-content: center; text-align: center; border-style: dashed; }
  .series-all:hover { border-style: dashed; }
  .series-all-inner { padding: 1.5rem 1rem; }
  .series-all-arrow { display: block; font-size: 2rem; line-height: 1; color: var(--accent); margin-bottom: .6rem; }
  .series-all h3 { font-family: var(--serif); font-size: 1.05rem; margin: 0 0 .2rem; color: var(--ink); }
  .series-all p { margin: 0; font-size: .8rem; color: var(--ink-soft); }

  @media (max-width: 480px) { .series-grid { grid-template-columns: repeat(2, 1fr); gap: .75rem; } }

  /* 可玩 · Plays —— 数据驱动的作品入口区，风格沿用站点 token */
  .plays { max-width: 72rem; margin: 0 auto; padding: 2.5rem 1.5rem .5rem; }
  .plays-head h2 { font-family: var(--serif); font-size: 1.5rem; margin: 0 0 .3rem; display: flex; align-items: baseline; gap: .5rem; }
  .plays-head h2 span { font-family: var(--sans); font-weight: 400; font-size: .78rem; letter-spacing: .26em; text-transform: uppercase; color: var(--ink-soft); }
  .plays-head p { margin: 0 0 1.3rem; color: var(--ink-soft); font-size: .92rem; max-width: 42rem; }

  .play-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(20.5rem, 1fr)); gap: 1rem; }

  .play-card {
    display: flex; gap: 1.1rem; align-items: flex-start; position: relative; overflow: hidden;
    border: 1px solid var(--line); border-radius: 16px; padding: 1.25rem 1.3rem; background: var(--paper-2);
    transition: transform .2s cubic-bezier(.2,.7,.3,1), box-shadow .2s ease, border-color .2s ease;
  }
  .play-card::before {
    content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 4px;
    background: linear-gradient(var(--g-accent, var(--accent)), color-mix(in srgb, var(--g-accent, var(--accent)) 45%, var(--accent-2)));
    opacity: 0; transition: opacity .2s ease;
  }
  .play-card:hover {
    transform: translateY(-4px); text-decoration: none;
    box-shadow: 0 16px 40px -16px rgba(var(--shadow), .5);
    border-color: color-mix(in srgb, var(--g-accent, var(--accent)) 55%, var(--line));
  }
  .play-card:hover::before { opacity: 1; }

  .play-badge {
    flex: none; width: 3.5rem; height: 3.5rem; border-radius: 13px; display: grid; place-items: center; font-size: 1.75rem;
    background: color-mix(in srgb, var(--g-accent, var(--accent)) 13%, var(--paper));
    border: 1px solid color-mix(in srgb, var(--g-accent, var(--accent)) 30%, var(--line));
  }
  .play-body { min-width: 0; }
  .play-status {
    display: inline-block; font-size: .66rem; letter-spacing: .14em; text-transform: uppercase;
    color: var(--g-accent, var(--accent)); margin-bottom: .5rem;
    border: 1px solid color-mix(in srgb, var(--g-accent, var(--accent)) 38%, var(--line)); border-radius: 999px; padding: .12em .6em;
  }
  .play-card h3 { font-family: var(--serif); font-size: 1.14rem; margin: 0 0 .2rem; color: var(--ink); }
  .play-tagline { margin: 0 0 .5rem; font-size: .9rem; color: var(--ink); opacity: .8; }
  .play-desc { margin: 0; font-size: .85rem; color: var(--ink-soft); line-height: 1.65; }
  .play-tags { display: flex; flex-wrap: wrap; gap: .35rem; margin: .75rem 0 0; }
  .play-tags span { font-size: .7rem; color: var(--ink-soft); border: 1px solid var(--line); border-radius: 999px; padding: .12em .65em; }
  .play-cta { display: inline-block; margin-top: .7rem; font-size: .82rem; font-weight: 600; color: var(--g-accent, var(--accent)); }

  .play-soon { border-style: dashed; opacity: .75; cursor: default; }
  .play-soon:hover { transform: none; box-shadow: none; border-color: var(--line); }
  .play-soon:hover::before { opacity: 0; }
  .play-soon .play-badge { font-size: 1.5rem; color: var(--ink-soft); background: var(--paper-3); border-color: var(--line); }

  @media (max-width: 480px) { .play-card { padding: 1.1rem; gap: .9rem; } .play-badge { width: 3rem; height: 3rem; font-size: 1.5rem; } }
</style>
