---
import '../styles/global.css';
import Search from '../components/Search.astro';
const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL;
const siteName = '蛛网之上';
const pageTitle = title ? `${title} · ${siteName}` : `${siteName} · 跳蛛先生创作知识库`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={`${base}favicon.svg`} />
    {/* 默认亮屏；读取用户上次选择，避免主题闪烁 */}
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('atw-theme');
          document.documentElement.setAttribute('data-theme', saved === 'dark' ? 'dark' : 'light');
        } catch (_) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="bar">
        <a class="brand" href={base}>
          蛛网之上
          <small>Above the Web</small>
        </a>
        <div class="header-actions">
          <Search />
          <button class="theme-toggle" id="theme-toggle" type="button" aria-label="切换昼夜主题" title="切换昼夜主题">
            <svg class="i-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/></svg>
            <svg class="i-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4.2"/><path d="M12 2v2.5M12 19.5V22M4.2 4.2l1.8 1.8M18 18l1.8 1.8M2 12h2.5M19.5 12H22M4.2 19.8 6 18M18 6l1.8-1.8"/></svg>
          </button>
          <a class="meta gh-link" href="https://github.com/Mr-Salticidae/knowledge-base" target="_blank" rel="noopener">源仓库 ↗</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>蛛网之上 · 跳蛛先生 / Mr-Salticidae 创作方法论知识库</p>
      <p>内容采用 <a href="https://github.com/Mr-Salticidae/knowledge-base/blob/main/LICENSE.md" target="_blank" rel="noopener">CC BY-NC 4.0</a> 许可 · 自动同步自 GitHub</p>
    </footer>

    <script is:inline>
      (() => {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', () => {
          const root = document.documentElement;
          const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          root.setAttribute('data-theme', next);
          try { localStorage.setItem('atw-theme', next); } catch (_) {}
          // 通知动画背景重新读取主题色
          window.dispatchEvent(new CustomEvent('themechange', { detail: { theme: next } }));
        });
      })();
    </script>
  </body>
</html>
