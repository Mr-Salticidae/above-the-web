---
import '../styles/global.css';
const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL;
const siteName = '蛛网之上';
const pageTitle = title ? `${title} · ${siteName}` : `${siteName} · 跳蛛先生创作知识库`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={`${base}favicon.svg`} />
  </head>
  <body>
    <header class="site-header">
      <div class="bar">
        <a class="brand" href={base}>
          蛛网之上
          <small>Above the Web</small>
        </a>
        <a class="meta" href="https://github.com/Mr-Salticidae/knowledge-base" target="_blank" rel="noopener">源仓库 ↗</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>蛛网之上 · 跳蛛先生 / Mr-Salticidae 创作方法论知识库</p>
      <p>内容采用 <a href="https://github.com/Mr-Salticidae/knowledge-base/blob/main/LICENSE.md" target="_blank" rel="noopener">CC BY-NC 4.0</a> 许可 · 自动同步自 GitHub</p>
    </footer>
  </body>
</html>
